DEFAULT_PLAN=basic
APP_BASE_URL=http://localhost:3000

# Đăng ký công khai (mặc định bật — set false để tắt)
# ALLOW_PUBLIC_SIGNUP=false

# Bắt buộc xác minh email trước khi đăng nhập (mặc định bật)
# REQUIRE_EMAIL_VERIFICATION=false

# Dev: in link xác minh ra console + API khi chưa cấu SMTP
EMAIL_VERIFICATION_DEV=true
EMAIL_CODE_TTL_MINUTES=15

# Email được phép xem toàn bộ khách đăng ký (phân cách bằng dấu phẩy)
SUPER_ADMIN_EMAILS=truongthanhsbay@gmail.com

# Username demo có quyền quản trị hệ thống (phân cách bằng dấu phẩy)
PLATFORM_ADMIN_USERNAMES=admin

# Khách tự đổi gói trên web (demo). Production: để false, chỉ SUPER_ADMIN đổi gói
# ALLOW_SELF_PLAN_CHANGE=true

# FREE trial (giờ)
FREE_TRIAL_HOURS=24

# SMTP (Gmail, SendGrid, Brevo…)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=app-password
# SMTP_FROM="Zalo CRM <your@gmail.com>"

PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zalo_crm
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=30
UPLOAD_DIR=./data/uploads
UPLOAD_MAX_BYTES=8388608
POSTGRES_PASSWORD=postgres
