# Copy → điền secret → Import vào Vercel (Settings → Environment Variables → Import .env)
#   copy .env.vercel.example .env.vercel
# KHÔNG commit file .env.vercel (đã gitignore)

# --- Bắt buộc ---
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require
JWT_SECRET=REPLACE_WITH_RANDOM_32_PLUS_CHARS
APP_BASE_URL=https://YOUR-PROJECT.vercel.app

# --- Gmail SMTP (OTP xác minh email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=truongthanhsbay@gmail.com
SMTP_PASS=REPLACE_GMAIL_APP_PASSWORD
SMTP_FROM=Zalo CRM <truongthanhsbay@gmail.com>

# --- Quản trị hệ thống (xem tất cả khách) ---
SUPER_ADMIN_EMAILS=truongthanhsbay@gmail.com
PLATFORM_ADMIN_USERNAMES=admin
# Mật khẩu tạo tài khoản admin lần đầu (bắt buộc nếu email chưa có trong DB)
PLATFORM_ADMIN_BOOTSTRAP_PASSWORD=111111
# Chỉ bật true MỘT LẦN để reset mật khẩu admin theo BOOTSTRAP_PASSWORD, rồi đặt lại false
PLATFORM_ADMIN_SYNC_PASSWORD=false

# --- Production ---
NODE_ENV=production
REQUIRE_EMAIL_VERIFICATION=true
ALLOW_SELF_PLAN_CHANGE=false
ALLOW_PUBLIC_SIGNUP=true
EMAIL_VERIFICATION_DEV=false
FREE_TRIAL_HOURS=24
EMAIL_CODE_TTL_MINUTES=15
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=30
DEFAULT_PLAN=basic
